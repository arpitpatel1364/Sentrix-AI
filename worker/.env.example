# Your Hub server URL
HUB_URL=https://your-hub-domain.com

# API key issued by admin for this specific worker PC
CLIENT_API_KEY=your_48_char_key_here

# Human-readable label for this worker (shown in admin/client dashboard)
WORKER_LABEL=Main Entrance

# Port this worker uses to serve snapshots and streams to the client dashboard
MEDIA_SERVER_PORT=8765

# Where to store snapshots on this PC
SNAPSHOT_DIR=/app/snapshots

# RTSP camera URLs — comma separated
# Example: rtsp://admin:pass@192.168.1.10:554/stream1,rtsp://...
CAMERA_URLS=rtsp://camera1_url,rtsp://camera2_url

# Camera display names — comma separated, same order as CAMERA_URLS
CAMERA_NAMES=Entrance Camera,Parking Camera
